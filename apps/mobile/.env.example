# Gateway base URL, including the /api suffix. Simulator can omit this (defaults
# to http://localhost:3000/api). On a physical device, point at the dev machine's
# LAN IP. Restart Metro with `expo start -c` after any change — EXPO_PUBLIC_* is
# baked into the bundle at build time.
# EXPO_PUBLIC_GATEWAY_URL=http://192.168.0.164:3000/api
